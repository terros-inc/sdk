{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "trailingComma": "es5",
  "tabWidth": 2,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "printWidth": 120,
  "ignorePatterns": [
    "node_modules/",
    "build",
    ".github",
    "patches",
    "CLAUDE.md",
    "pnpm-lock.yaml",
    "package.json",
    "tsconfig.json"
  ],
  "sortImports": {
    "newlinesBetween": false,
    "order": "desc",
    "groups": ["side_effect", "builtin", "external", "internal", "parent", "sibling", "index"]
  }
}
